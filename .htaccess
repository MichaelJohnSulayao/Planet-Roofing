# =========================================
# PLANET ROOFING .HTACCESS - HTML WEBSITE
# https://planetroofingfl.com
# =========================================

Options -Indexes
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

# =========================================
# FORCE HTTPS + NON-WWW
# =========================================

# =========================================
# REMOVE DOUBLE SLASHES
# =========================================

RewriteCond %{THE_REQUEST} \s/+(.*/)/+([^\s?]*) [NC]
RewriteRule ^ %1%2 [R=301,L]

# =========================================
# 301 REDIRECTS - OLD URLS TO NEW URLS
# =========================================

# Financing
RewriteRule ^roof-financing-offers-in-fort-lauderdale-fl/?$ /roof-financing-fort-lauderdale-fl/ [R=301,L]
RewriteRule ^contact-for-roof-financing-option/?$ /roof-financing-fort-lauderdale-fl/ [R=301,L]

# Blogs
